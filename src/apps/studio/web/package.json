{
  "name": "studio-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "lint": "eslint . && prettier --check .",
    "typecheck": "node --max-old-space-size=4096 --max-semi-space-size=256 ./node_modules/typescript/bin/tsc --noEmit",
    "test": "bddgen && playwright test",
    "test:record": "cross-env PLAYWRIGHT_UPDATE_HAR=1 bddgen && cross-env PLAYWRIGHT_UPDATE_HAR=1 playwright test",
    "build": "node --max-old-space-size=4096 --max-semi-space-size=256 ./node_modules/typescript/bin/tsc --noEmit && vite build",
    "orval": "orval --config orval.config.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "*",
    "axios": "*",
    "design-system": "workspace:*",
    "react": "19",
    "react-dom": "19",
    "shared-types": "workspace:*",
    "ts-pattern": "*"
  },
  "devDependencies": {
    "@playwright/test": "*",
    "@types/react": "*",
    "@types/react-dom": "*",
    "@vitejs/plugin-react": "*",
    "cross-env": "*",
    "orval": "*",
    "playwright-bdd": "*",
    "sass": "*",
    "typescript": "*",
    "vite": "*"
  }
}
