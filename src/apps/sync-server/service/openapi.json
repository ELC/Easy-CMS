{
  "components": {
    "schemas": {
      "HealthResponse": {
        "properties": {
          "service": {
            "$ref": "#/components/schemas/ServiceIdentity"
          },
          "status": {
            "$ref": "#/components/schemas/HealthStatus"
          }
        },
        "required": ["status", "service"],
        "title": "HealthResponse",
        "type": "object"
      },
      "HealthStatus": {
        "enum": ["healthy"],
        "title": "HealthStatus",
        "type": "string"
      },
      "ProblemDetails": {
        "properties": {
          "detail": {
            "title": "Detail",
            "type": "string"
          },
          "instance": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Instance"
          },
          "status": {
            "title": "Status",
            "type": "integer"
          },
          "title": {
            "title": "Title",
            "type": "string"
          },
          "type": {
            "title": "Type",
            "type": "string"
          }
        },
        "required": ["type", "title", "status", "detail"],
        "title": "ProblemDetails",
        "type": "object"
      },
      "ServiceIdentity": {
        "enum": ["studio-service", "sync-server-service"],
        "title": "ServiceIdentity",
        "type": "string"
      },
      "VersionResponse": {
        "properties": {
          "service": {
            "$ref": "#/components/schemas/ServiceIdentity"
          },
          "version": {
            "title": "Version",
            "type": "string"
          }
        },
        "required": ["version", "service"],
        "title": "VersionResponse",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "Sync Server",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/health": {
      "get": {
        "operationId": "read_health_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "service": "sync-server-service",
                  "status": "healthy"
                },
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "503": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/problem+json": {
                "example": {
                  "detail": "Sync Server health could not be reported.",
                  "status": 503,
                  "title": "Health unavailable",
                  "type": "/problems/health-unavailable"
                }
              }
            },
            "description": "Service Unavailable"
          }
        },
        "summary": "Read Health",
        "tags": ["health"]
      }
    },
    "/version": {
      "get": {
        "operationId": "read_version_version_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "example": {
                  "service": "sync-server-service",
                  "version": "0.1.0"
                },
                "schema": {
                  "$ref": "#/components/schemas/VersionResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "500": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/problem+json": {
                "example": {
                  "detail": "Sync Server version could not be reported.",
                  "status": 500,
                  "title": "Version unavailable",
                  "type": "/problems/version-unavailable"
                }
              }
            },
            "description": "Internal Server Error"
          }
        },
        "summary": "Read Version",
        "tags": ["version"]
      }
    }
  }
}
